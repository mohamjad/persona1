{
  "name": "persona1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "corepack pnpm build && node --test tests/**/*.test.mjs",
    "baml:check": "node node_modules/@boundaryml/baml/cli.js check",
    "baml:generate": "node node_modules/@boundaryml/baml/cli.js generate",
    "dev:api": "node dist/apps/persona1-api/src/main.js",
    "start:api": "corepack pnpm build && node dist/apps/persona1-api/src/main.js",
    "validate:extension": "node apps/persona1-ext/scripts/validate-extension.mjs",
    "smoke:api": "corepack pnpm build && node scripts/smoke-api.mjs",
    "smoke:extension": "corepack pnpm build && node scripts/smoke-extension.mjs"
  },
  "dependencies": {
    "@boundaryml/baml": "^0.220.0",
    "@floating-ui/dom": "^1.7.6",
    "@formkit/auto-animate": "^0.9.0",
    "@langchain/langgraph": "^1.2.2",
    "@microsoft/recognizers-text-suite": "^1.3.1",
    "@xenova/transformers": "^2.17.2",
    "dexie": "^4.3.0",
    "json-rules-engine": "^7.3.1",
    "motion": "^12.37.0",
    "openskill": "^4.1.1",
    "pg": "^8.16.3",
    "pgvector": "^0.2.1",
    "stripe": "^18.5.0",
    "tinykeys": "^3.0.0",
    "webext-bridge": "^6.0.1",
    "yaml": "^2.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@types/pg": "^8.15.5",
    "playwright": "^1.58.2",
    "typescript": "^5.8.2"
  }
}
