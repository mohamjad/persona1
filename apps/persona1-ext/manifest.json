{
  "manifest_version": 3,
  "name": "persona1",
  "version": "0.1.0",
  "description": "Conversation intelligence that shows the board before you send.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "persona1",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "toggle_sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Toggle the persona1 inline HUD"
    },
    "analyze": {
      "suggested_key": {
        "default": "Ctrl+Shift+A"
      },
      "description": "Analyze the current compose box"
    },
    "copy_selected": {
      "suggested_key": {
        "default": "Ctrl+Shift+C"
      },
      "description": "Copy the selected option"
    },
    "collapse_sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+X"
      },
      "description": "Collapse the active HUD"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "vendor/auto-animate.mjs",
        "vendor/dexie.mjs",
        "vendor/floating-ui.dom.mjs",
        "vendor/tinykeys.mjs",
        "vendor/motion-waapi.mjs",
        "vendor/webext-bridge/*.js",
        "vendor/webext-bridge/deps/*.js",
        "lib/content-bridge.js",
        "lib/messages.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
